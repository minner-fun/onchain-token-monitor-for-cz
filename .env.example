# check.py and the balance/critical signals run against a public BSC RPC out of the box.

# Optional custom BSC RPC endpoint (default: https://bsc-dataseed.binance.org).
# The default covers balanceOf (cold-wallet critical alert). To also NAME outflow
# destinations you need eth_getLogs — point this at a logs-capable node
# (self-hosted / Ankr / Alchemy / QuickNode).
BSC_RPC=

# Optional Telegram alerts (leave blank to only print + write to DB)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: network early-warning (funder_watch). A free BscScan / Etherscan V2 key lets the
# monitor watch the Binance-funded paymaster and alert on large BNB outflows (new-pump capital).
# Get one at https://etherscan.io/apis (works for BSC via chainid=56). Skipped if blank.
BSCSCAN_API_KEY=
